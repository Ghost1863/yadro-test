extends: default

ignore: |
  **/.venv/
  **/venv/
  section3/collections/
  section3/roles/*/molecule/*/.molecule/

rules:
  line-length: disable
  document-start: disable
  truthy: disable
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  indentation:
    spaces: 2
    indent-sequences: consistent
